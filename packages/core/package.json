{
  "name": "@autolink/sdk",
  "version": "0.2.2",
  "description": "Official Autolink SDK for Node.js — server-side inventory, inquiries, and dealer data",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "msw": "^2.6.8",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Autolinkventures/autolink-node"
  },
  "keywords": [
    "autolink",
    "sdk",
    "inventory",
    "dealership",
    "kenya"
  ]
}
