{
  "name": "@autolink/sdk",
  "version": "0.1.0",
  "description": "Official Autolink SDK for Node.js — server-side inventory, inquiries, and dealer data",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "vitest": "^2.1.8",
    "msw": "^2.6.8",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  },
  "engines": { "node": ">=20" },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Autolinkventures/autolink-js-sdk"
  },
  "keywords": ["autolink", "sdk", "inventory", "dealership", "kenya"]
}
