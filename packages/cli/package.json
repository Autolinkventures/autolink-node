{
  "name": "@autolink/cli",
  "version": "0.1.0",
  "description": "CLI tools for Autolink SDK integration — init and verify",
  "bin": {
    "autolink": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
