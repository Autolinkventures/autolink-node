  },
  "dependencies": {
    "@autolink/sdk": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  },
  "engines": { "node": ">=20" },
  "license": "MIT"
}
