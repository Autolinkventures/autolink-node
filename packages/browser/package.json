{
  "name": "@autolink/browser",
  "version": "0.2.8",
  "description": "Autolink browser SDK — embed live dealer inventory without a server",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@autolink/sdk": "workspace:*"
  },
  "devDependencies": {
    "msw": "^2.6.8",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
